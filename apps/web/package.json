{
  "name": "@apps/web",
  "version": "1.0.0",
  "main": "scripts/index.ts",
  "repository": "git@github.com.bylegal:attivita/front-end-boilerplate.git",
  "author": "kota <k.ichikawa@attivita.co.jp>",
  "license": "MIT",
  "scripts": {
    "rm-dist": "rm -rf dist",
    "dev": "cross-env ENV=local vite",
    "dev:wp": "vite --config vite.config.csr.ts",
    "build:prerender": "vite build",
    "build": "pnpm rm-dist && pnpm build:prerender",
    "build:csr": "vite build --config vite.config.csr.ts",
    "build:wp": "pnpm rm-dist && pnpm build:csr && BUILD_TYPE=wp pnpm build:prerender",
    "start": "browser-sync start -s 'dist/client'",
    "start:csr": "browser-sync start -s 'dist/csr'",
    "tsc": "tsc --noEmit",
    "lint": "pnpm biome check --diagnostic-level=warn .",
    "lint:fix": "pnpm biome check --diagnostic-level=warn --write ."
  },
  "dependencies": {
    "@packages/context": "workspace:*",
    "@packages/hooks": "workspace:*",
    "@packages/ui": "workspace:*",
    "@packages/utils": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "babel-plugin-styled-components": "^2.1.4",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "sharp": "^0.34.4",
    "vike": "^0.4.244",
    "vike-react": "^0.6.10",
    "vite": "^7.1.11",
    "vite-plugin-image-optimizer": "^2.0.2"
  }
}
