{
  "compilerOptions": {
    // モダンブラウザ & Vite 前提
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    // TS 5 以上なら Bundler 推奨（Vite 向け）
    "moduleResolution": "Bundler",

    // React 17+ の自動 JSX 変換
    "jsx": "react-jsx",

    // 品質・互換
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true, // Viteのトランスパイルと相性◎
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,

    // Vite の import.meta/env 型
    "types": ["vite/client"],

    // 任意：エイリアス（@/xxx → src/xxx）
    "baseUrl": "."
  },
  "include": [
    "./src/**/*",
    "vite.config.common.ts",
    "vite.config.csr.ts",
    "vite.config.ts",
    "./@types/**/*"
  ]
}
