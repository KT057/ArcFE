include ../../../Icon/template/_component

mixin ListItem003({ key = 'default', href = '#', animation = '001' })
  .cm-list-item-003__wrapper(class=`cm-list-item-003__wrapper--${key}`)
    a.cm-list-item-003(href=href, class=`cm-list-item-003--animation_${animation}`)
      .cm-list-item-003__point-wrapper
        .cm-list-item-003__point
      .cm-list-item-003__text-wrapper
        .cm-list-item-003__text
          block
