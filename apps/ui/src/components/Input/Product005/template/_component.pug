//- .js-inputにerrorクラスを付与するとエラー表示が出る

mixin Input005({ key = 'default', type = '001', size = 'small', name = 'input-005', placeholder = '入力してください' })
  block
  .cm-input-005__wrapper(class=`cm-input-005__wrapper--${key}`)
    .js-input.cm-input-005(class=`cm-input-005--${type} cm-input-005--size_${size}`)
      input.cm-input-005__input(name=name, type='text', placeholder=placeholder)
      p.cm-input-005__error 
        +errorText
