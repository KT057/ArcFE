{
  "name": "@packages/context",
  "version": "2.0.0",
  "description": "Context for the application",
  "author": "Kota Ichikawa",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup index.ts --format esm --dts --out-dir dist",
    "tsc": "tsc --noEmit --project tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "peerDependencies": {
    "axios": "^1.13.2",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
