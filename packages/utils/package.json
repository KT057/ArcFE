{
  "name": "@packages/utils",
  "version": "2.1.0",
  "description": "Utils for the application",
  "author": "Kota Ichikawa",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup index.ts --format esm --dts --out-dir dist",
    "tsc": "tsc --noEmit --project tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.12.1"
}
