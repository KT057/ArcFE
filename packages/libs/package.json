{
  "name": "@packages/libs",
  "version": "1.4.0",
  "description": "Core library scripts for the application",
  "author": "Kota Ichikawa",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup index.ts --format esm --dts --out-dir dist",
    "tsc": "tsc --noEmit --project tsconfig.json",
    "lint": "pnpm biome check --diagnostic-level=warn .",
    "lint:fix": "pnpm biome check --diagnostic-level=warn --write .",
    "prepublishOnly": "pnpm run build"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.1"
  }
}
