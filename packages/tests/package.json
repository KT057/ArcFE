{
  "name": "@packages/tests",
  "version": "2.2.0",
  "description": "Tests for the application",
  "author": "Kota Ichikawa",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.mts"
    }
