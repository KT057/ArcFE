{
  "name": "@packages/ui",
  "version": "2.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --external react --external react-dom --external styled-components",
    "gen:icons": "ts-node svgr/scripts/generateIcons.ts && pnpm lint:fix",
    "storybook": "storybook dev -p 6006",
    "test-storybook": "vitest --project=storybook --run",
    "debug": "browser-sync start -s 'storybook-static'",
    "build-storybook": "storybook build",
    "tsc": "tsc --noEmit --project tsconfig.json",
    "lint": "pnpm biome check --diagnostic-level=warn .",
    "lint:fix": "pnpm biome check --diagnostic-level=warn --write .",
    "test:storybook": "vitest --run --project=storybook",
    "reg-suit:run": "reg-suit run",
    "reg-suit:publish": "reg-suit publish",
    "install:playwright:browser": "npx playwright install --with-deps chromium",
    "prepublishOnly": "pnpm run build"
  },
  "packageManager": "pnpm@10.12.1",
  "peerDependencies": {
    "gsap": "^3.13.0",
    "keen-slider": "^6.8.6",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "styled-components": "^6.1.19",
    "swiper": "^11.0.0 || ^12.0.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.0.7",
    "@storybook/addon-onboarding": "^10.0.7",
    "@storybook/addon-themes": "^10.0.7",
    "@storybook/addon-vitest": "^10.0.7",
    "@storybook/react": "^10.0.7",
    "@storybook/react-vite": "^10.0.7",
    "@storycap-testrun/browser": "^2.0.0",
    "@svgr/webpack": "^8.1.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser": "4.0.10",
    "@vitest/browser-playwright": "^4.0.10",
    "@vitest/coverage-v8": "4.0.10",
    "playwright": "^1.56.1",
    "react-dom": "^19.2.0",
    "reg-keygen-git-hash-plugin": "^0.14.5",
    "reg-notify-github-plugin": "^0.14.5",
    "reg-publish-s3-plugin": "^0.14.4",
    "reg-suit": "^0.14.5",
    "storybook": "^10.0.7",
    "ts-node": "^10.9.2",
    "vite": "^7.2.2"
  },
  "dependencies": {
    "@packages/libs": "workspace:*",
    "@react-aria/button": "^3.14.2",
    "@react-aria/i18n": "^3.12.13",
    "@react-aria/listbox": "^3.15.0",
    "@react-aria/select": "^3.17.0",
    "@react-aria/textfield": "^3.18.2",
    "@react-aria/utils": "^3.31.0",
    "@react-stately/select": "^3.8.0",
    "dotenv": "^17.2.3"
  }
}
