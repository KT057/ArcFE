{
  "name": "@packages/ui",
  "version": "1.0.0",
  "scripts": {
    "gen:icons": "npx @svgr/cli -d ./components/Basic/Icons ./svgr/icons --replace-attr-values '#000=currentColor' && ts-node svgr/scripts/generateIconComponentForStorybook.ts && pnpm lint:script:fix",
    "storybook": "storybook dev -p 6006",
    "test-storybook": "vitest --project=storybook --run",
    "debug": "browser-sync start -s 'storybook-static'",
    "build-storybook": "storybook build",
    "tsc": "tsc --noEmit --project tsconfig.json",
    "lint": "pnpm biome check --diagnostic-level=warn .",
    "lint:fix": "pnpm biome check --diagnostic-level=warn --write .",
    "test:storybook": "vitest --run --project=storybook",
    "reg-suit:run": "reg-suit run",
    "reg-suit:publish": "reg-suit publish",
    "install:playwright:browser": "npx playwright install --with-deps chromium"
  },
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@storybook/addon-docs": "^9.1.10",
    "@storybook/addon-onboarding": "^9.1.10",
    "@storybook/addon-themes": "^9.1.10",
    "@storybook/addon-vitest": "^9.1.10",
    "@storybook/react": "^9.1.10",
    "@storybook/react-vite": "^9.1.10",
    "@storycap-testrun/browser": "^2.0.0",
    "@svgr/webpack": "^8.1.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/browser": "4.0.6",
    "@vitest/browser-playwright": "^4.0.6",
    "@vitest/coverage-v8": "4.0.6",
    "playwright": "^1.56.1",
    "react-dom": "^19.2.0",
    "reg-keygen-git-hash-plugin": "^0.14.5",
    "reg-notify-github-plugin": "^0.14.5",
    "reg-publish-s3-plugin": "^0.14.4",
    "reg-suit": "^0.14.5",
    "storybook": "^9.1.10",
    "ts-node": "^10.9.2",
    "vite": "^7.1.12"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
