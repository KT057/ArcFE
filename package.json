{
  "name": "root",
  "version": "2.2.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "@ui": "pnpm --filter @packages/ui",
    "@web": "pnpm --filter @apps/web",
    "@libs": "pnpm --filter @packages/libs",
    "test": "vitest --run",
    "tsc": "pnpm --filter @packages/libs tsc && pnpm --filter @packages/tests tsc && pnpm --filter @packages/hooks tsc && pnpm --filter @packages/context tsc && pnpm --filter @packages/utils tsc",
    "tsc:scripts": "tsc --noEmit --project tsconfig.scripts.json",
    "lint:scripts": "biome check scripts",
    "lint:scripts:fix": "biome check --diagnostic-level=warn --write scripts",
    "build:packages": "pnpm --filter @packages/libs build && pnpm --filter @packages/utils build && pnpm --filter @packages/context build && pnpm --filter @packages/hooks build && pnpm --filter @packages/ui build",
    "catalog:build": "tsx scripts/quickstart-catalog.ts",
    "catalog:embeddings": "python3 scripts/generate-embeddings.py",
    "catalog:all": "pnpm @ui test-storybook && pnpm catalog:build",
    "changeset": "changeset",
    "changeset:add": "node scripts/create-changeset.mjs",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "pnpm catalog:all && pnpm build:packages && pnpm changeset:version && node scripts/sync-root-version.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@changesets/cli": "^2.29.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/browser-sync": "^2.29.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.48.1",
    "@typescript-eslint/typescript-estree": "^8.48.1",
    "browser-sync": "^3.0.4",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "glob": "^13.0.6",
    "jsdom": "^27.2.0",
    "msw": "^2.12.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "webpack": "^5.103.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-aria/focus": "^3.21.2",
    "@react-aria/radio": "^3.12.2",
    "@react-aria/visually-hidden": "^3.8.28",
    "@react-stately/radio": "^3.11.2",
    "@react-types/radio": "^3.9.2",
    "@vis.gl/react-google-maps": "^1.7.1",
    "axios": "^1.13.2",
    "gsap": "^3.13.0",
    "keen-slider": "^6.8.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-scroll-parallax": "^3.5.0",
    "simple-parallax-js": "^6.3.3",
    "styled-components": "^6.1.19",
    "swiper": "^12.0.3"
  },
  "engines": {
    "npm": "use pnpm please!",
    "yarn": "use pnpm please!",
    "pnpm": ">=10.1.0"
  },
  "pnpm": {
    "overrides": {
      "vitest": "^4.0.15",
      "@vitest/browser": "^4.0.15",
      "@vitest/runner": "^4.0.15",
      "@vitest/utils": "^4.0.15",
      "react": "19.2.5",
      "react-dom": "19.2.5"
    }
  }
}
