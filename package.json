{
  "name": "front-end-boilerplate",
  "version": "1.0.0",
  "main": "scripts/index.ts",
  "repository": "git@github.com.bylegal:attivita/front-end-boilerplate.git",
  "author": "kota <k.ichikawa@attivita.co.jp>",
  "license": "MIT",
  "scripts": {
    "start": "yarn local",
    "local": "cross-env NODE_ENV=local ts-node scripts/index.ts",
    "build": "rimraf ./production && cross-env NODE_ENV=production ts-node scripts/index.ts",
    "debug": "browser-sync start -s 'production'",
    "tsc": "tsc --noEmit",
    "lint:template": "pug-lint -c .pug-lint.json .",
    "lint:style": "stylelint --ignore-path .stylelintignore \"**/*.scss\"",
    "lint:style:fix": "stylelint --fix --ignore-path .stylelintignore \"**/*.scss\"",
    "lint:script": "eslint --cache src/**/*.ts",
    "lint:script:fix": "eslint --fix src/**/*.ts",
    "format": "prettier 'src/**/*.{js,ts,json}'",
    "format:fix": "prettier --write 'src/**/*.{js,ts,json}'",
    "sys:dev": "cross-env NODE_ENV=local ts-node-dev --respawn scripts/index.ts",
    "sys:format": "prettier 'scripts/**/*.{js,ts,json}'",
    "sys:format:fix": "prettier --write 'scripts/**/*.{js,ts,json}'",
    "sys:lint": "eslint scripts/**/*.ts",
    "sys:lint:fix": "eslint scripts/**/*.ts --fix",
    "fix": "yarn format:fix && yarn lint:style:fix && yarn lint:script:fix && yarn sys:format:fix && yarn sys:lint:fix",
    "ci:check": "yarn tsc && yarn format && yarn lint:template && yarn lint:style && yarn lint:script",
    "ci:sys:check": "yarn sys:format && yarn sys:lint"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-es2015": "^7.0.0-beta.53",
    "@babel/register": "^7.27.1",
    "@babel/runtime": "^7.27.1",
    "@types/browser-sync": "^2.29.0",
    "@types/css-declaration-sorter": "^6.0.4",
    "@types/cssnano": "^5.1.3",
    "@types/mkdirp": "^2.0.0",
    "@types/node": "^22.15.17",
    "@types/node-sass": "^4.11.8",
    "@types/postcss-calc": "^8.2.0",
    "@types/postcss-reporter": "^7.0.5",
    "@types/pug": "^2.0.10",
    "@types/webpack-dev-middleware": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "autoprefixer": "^10.4.21",
    "babel": "^6.23.0",
    "babel-core": "^6.26.3",
    "babel-eslint": "^10.1.0",
    "babel-loader": "^10.0.0",
    "browser-sync": "^3.0.4",
    "chalk": "^5.4.1",
    "child_process": "^1.0.2",
    "chokidar": "^4.0.3",
    "cross-env": "^7.0.3",
    "css-declaration-sorter": "^7.2.0",
    "css-loader": "^7.1.2",
    "cssnano": "^7.0.7",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-webpack-plugin": "^5.0.1",
    "formatter": "^0.4.2",
    "glob": "^11.0.2",
    "imagemin-mozjpeg": "^10.0.0",
    "mkdirp": "^3.0.1",
    "postcss": "^8.5.3",
    "postcss-combine-media-query": "^2.0.0",
    "postcss-nested": "^7.0.2",
    "postcss-reporter": "^7.1.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.5.3",
    "pug": "^3.0.3",
    "pug-lint": "^2.7.0",
    "puglint-stylish": "^1.1.0",
    "sass": "^1.87.0",
    "sharp": "^0.34.1",
    "style-loader": "^4.0.0",
    "stylelint": "^16.19.1",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-recommended-scss": "^15.0.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-scss": "^6.12.0",
    "svgo": "^3.3.2",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "webpack": "^5.99.8",
    "webpack-dev-middleware": "^7.4.2",
    "webpack-dev-server": "^5.2.1"
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "simple-parallax-js": "^6.1.1",
    "swiper": "^11.2.6"
  }
}
