{
  "name": "root",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "@ui": "pnpm --filter @packages/ui",
    "@web": "pnpm --filter @apps/web",
    "@wp": "pnpm --filter @apps/wordpress",
    "test": "vitest --run",
    "tsc": "pnpm --filter @packages/tests tsc && pnpm --filter @packages/hooks tsc && pnpm --filter @packages/context tsc && pnpm --filter @packages/utils tsc",
    "build:packages": "pnpm --filter @packages/utils build && pnpm --filter @packages/tests build && pnpm --filter @packages/context build && pnpm --filter @packages/hooks build && pnpm --filter @packages/ui build",
    "changeset": "changeset",
    "changeset:add": "node scripts/create-changeset.mjs",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build:packages && changeset publish",
    "version:packages": "pnpm changeset:version && pnpm build:packages",
    "commit:dist": "bash scripts/commit-dist.sh",
    "tag:packages": "node scripts/tag-packages.mjs",
    "release": "pnpm version:packages && pnpm commit:dist && pnpm tag:packages"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@changesets/cli": "^2.29.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/browser-sync": "^2.29.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "browser-sync": "^3.0.4",
    "cross-env": "^10.1.0",
    "jsdom": "^27.1.0",
    "msw": "^2.11.6",
    "tsup": "^8.5.0",
    "turbo": "^2.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6",
    "webpack": "^5.102.1"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@vis.gl/react-google-maps": "^1.7.0",
    "axios": "^1.13.1",
    "gsap": "^3.13.0",
    "keen-slider": "^6.8.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-scroll-parallax": "^3.5.0",
    "simple-parallax-js": "^6.3.3",
    "styled-components": "^6.1.19",
    "swiper": "^12.0.3"
  },
  "engines": {
    "npm": "use pnpm please!",
    "yarn": "use pnpm please!",
    "pnpm": ">=10.1.0"
  }
}
