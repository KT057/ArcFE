{
  "name": "root",
  "version": "1.0.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "setup": "pnpm install && pnpm @core build",
    "ui:gen": "rm -rf apps/web/src/shared/common && rm -rf apps/wordpress/src/shared/common && pnpm @ui gen",
    "@ui": "pnpm --filter @apps/ui",
    "@web": "pnpm --filter @apps/web",
    "@wp": "pnpm --filter @apps/wordpress",
    "@core": "pnpm --filter @core"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/browser-sync": "^2.29.0",
    "browser-sync": "^3.0.4",
    "cross-env": "^10.0.0",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3",
    "webpack": "^5.101.2"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "gsap": "^3.13.0",
    "keen-slider": "^6.8.6",
    "react-scroll-parallax": "^3.4.5",
    "simple-parallax-js": "^6.2.1",
    "styled-components": "^6.1.19",
    "swiper": "^11.2.10"
  },
  "engines": {
    "npm": "use pnpm please!",
    "yarn": "use pnpm please!",
    "pnpm": ">=10.1.0"
  }
}
